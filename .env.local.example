# ================================================================
# LovMedSpa Review Funnel — Environment Variables
# ================================================================
# Copy this file to .env.local and fill in the real values
# NEVER commit .env.local to git
# ================================================================

# ────────────────────────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────────────────────
# Anthropic (AI Review Generation)
# Get from: https://console.anthropic.com/settings/keys
# ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional — override the model. Defaults to claude-sonnet-4-5.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ────────────────────────────────────────────────────────────────
# Resend (Email Alerts for Negative Feedback)
# Get from: https://resend.com/api-keys
# ────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Optional: custom from-address (must match a verified domain in Resend)
# Default uses Resend's test sender — fine for testing, replace before going live
RESEND_FROM_EMAIL=Reviews <reviews@yourdomain.com>

# ────────────────────────────────────────────────────────────────
# Upstash Redis (Rate Limiting)
# Get from: https://console.upstash.com → Redis → REST API
# ────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ────────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://reviews.seenai.com
# For local dev use: http://localhost:3000

# ────────────────────────────────────────────────────────────────
# Admin Dashboard Secret
# Used to access /admin — MUST be at least 24 characters.
# Generate with: `openssl rand -hex 32`  (or https://www.random.org/strings/)
# Then access admin at: https://reviews.seenai.com/admin?key=YOUR_SECRET
# The middleware gate will return 404 if the secret is missing, the placeholder,
# under 24 chars, or the ?key= does not match (timing-safe comparison).
# ────────────────────────────────────────────────────────────────
ADMIN_SECRET=change-me-to-a-long-random-string-32chars-min

# ────────────────────────────────────────────────────────────────
# Global Anthropic spend cap (safety net)
# Caps total AI reviews generated per calendar month across ALL clients.
# Default: 5000 reviews/month = ~$50/mo at $0.01 per review.
# Increase if you onboard many clients. Service returns 503 once hit.
# ────────────────────────────────────────────────────────────────
MAX_AI_REVIEWS_PER_MONTH=5000
