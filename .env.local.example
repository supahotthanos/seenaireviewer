# ================================================================
# LovMedSpa Review Funnel — Environment Variables
# ================================================================
# Copy this file to .env.local and fill in the real values
# NEVER commit .env.local to git
# ================================================================

# ────────────────────────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ────────────────────────────────────────────────────────────────
# Anthropic (AI Review Generation)
# Get from: https://console.anthropic.com/settings/keys
# ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ────────────────────────────────────────────────────────────────
# Resend (Email Alerts for Negative Feedback)
# Get from: https://resend.com/api-keys
# ────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ────────────────────────────────────────────────────────────────
# Upstash Redis (Rate Limiting)
# Get from: https://console.upstash.com → Redis → REST API
# ────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ────────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://reviews.seenai.com
# For local dev use: http://localhost:3000
